<Window x:Class="PersonalAutomationTool.Modules.Email.RecipientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Destinatari Email" Height="360" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5" WindowStyle="ToolWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Text="Destinatari per: " FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15" Grid.Row="0"/>
        
        <!-- riga A... -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="A..." Width="70" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Background="#E1E1E1" BorderBrush="#ADADAD" BorderThickness="1" Cursor="Hand" ToolTip="Destinatari principali"/>
            <TextBox x:Name="TxtToRecipients" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="25" MaxHeight="60" 
                     VerticalScrollBarVisibility="Auto" Padding="3" FontSize="13" BorderBrush="#ABADB3" BorderThickness="1"/>
        </Grid>
        
        <!-- riga Cc... -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Cc..." Width="70" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Background="#E1E1E1" BorderBrush="#ADADAD" BorderThickness="1" Cursor="Hand" ToolTip="Destinatari per conoscenza"/>
            <TextBox x:Name="TxtCcRecipients" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="25" MaxHeight="60" 
                     VerticalScrollBarVisibility="Auto" Padding="3" FontSize="13" BorderBrush="#ABADB3" BorderThickness="1"/>
        </Grid>

        <!-- riga Ccn... -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Ccn..." Width="70" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Background="#E1E1E1" BorderBrush="#ADADAD" BorderThickness="1" Cursor="Hand" ToolTip="Copia conoscenza nascosta"/>
            <TextBox x:Name="TxtBccRecipients" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="25" MaxHeight="60" 
                     VerticalScrollBarVisibility="Auto" Padding="3" FontSize="13" BorderBrush="#ABADB3" BorderThickness="1"/>
        </Grid>

        <TextBlock Grid.Row="4" Text="Separare i nomi con il punto e virgola (;)" FontSize="12" Foreground="#666666" Margin="80,0,0,0" VerticalAlignment="Top"/>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="80" Height="26" Margin="0,0,10,0" Click="BtnSave_Click" 
                    Background="#E1E1E1" BorderBrush="#ADADAD" BorderThickness="1" Cursor="Hand"/>
            <Button Content="Annulla" Width="80" Height="26" Click="BtnCancel_Click" 
                    Background="#E1E1E1" BorderBrush="#ADADAD" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
