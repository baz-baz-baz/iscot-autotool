<UserControl x:Class="PersonalAutomationTool.Modules.Pdf.PdfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:PersonalAutomationTool.Core.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="Transparent" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dashboard PDF" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsControlCards" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="15">
                            <Expander IsExpanded="True" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#1E3A8A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        
                                        <!-- Colorful Rinomina Button -->
                                        <Border Grid.Column="1" Background="#0284C7" CornerRadius="6" Margin="0,0,10,0">
                                            <Button Content="Rinomina" CommandParameter="{Binding}" Click="BtnRinomina_Click"
                                                    Background="Transparent" Foreground="White" BorderThickness="0" FontWeight="Bold" Padding="12,6" />
                                        </Border>
                                        
                                        <!-- Colorful ND CheckBox Area -->
                                        <Border Grid.Column="2" Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="10,6">
                                            <CheckBox IsChecked="{Binding IsND}" Content="ND" VerticalAlignment="Center" FontWeight="Bold" Foreground="#B45309"/>
                                        </Border>

                                        <!-- Colorful Apri Button -->
                                        <Border Grid.Column="3" Background="#10B981" CornerRadius="6" Margin="0,0,10,0">
                                            <Button Content="Apri" CommandParameter="{Binding}" Click="BtnApri_Click"
                                                    Background="Transparent" Foreground="White" BorderThickness="0" FontWeight="Bold" Padding="12,6" />
                                        </Border>
                                    </Grid>
                                </Expander.Header>
                                
                                <ItemsControl ItemsSource="{Binding Children}" Margin="10,15,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="20,6,0,6">
                                                <!-- Colorful Icons -->
                                                <TextBlock Text="📁" Foreground="#F59E0B" FontSize="16" Visibility="{Binding IsDirectory, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,8,0"/>
                                                
                                                <!-- CheckBox per file PDF -->
                                                <CheckBox Content="NC" IsChecked="{Binding IsNC}" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#DC2626">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Extension}" Value=".pdf">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>

                                                <!-- Dynamic File Icon -->
                                                <TextBlock FontSize="16" Visibility="{Binding IsDirectory, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Margin="0,0,8,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Text" Value="📄" />
                                                            <Setter Property="Foreground" Value="#94A3B8" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Extension}" Value=".pdf">
                                                                    <Setter Property="Text" Value="📕" />
                                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Extension}" Value=".txt">
                                                                    <Setter Property="Text" Value="📝" />
                                                                    <Setter Property="Foreground" Value="#64748B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Extension}" Value=".xlsx">
                                                                    <Setter Property="Text" Value="📊" />
                                                                    <Setter Property="Foreground" Value="#10B981" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <TextBlock Text="{Binding Name}" FontSize="15" Foreground="#334155" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
