<Window x:Class="PersonalAutomationTool.Modules.DestinatariMail.RubricaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleziona dalla Rubrica" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Rubrica Indirizzi" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Seleziona i contatti da aggiungere." FontSize="14" Foreground="#64748B"/>
            </StackPanel>
            
            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" VerticalAlignment="Center" Padding="5,5,10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Foreground="#94A3B8" Margin="5,0,8,0" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <TextBlock Text="Cerca contatto..." Foreground="#94A3B8" IsHitTestVisible="False" Margin="2,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchTextBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchTextBox" BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" FontSize="14" Foreground="#1E293B" 
                                 TextChanged="SearchTextBox_TextChanged" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="2">
            <DataGrid x:Name="ContactsGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="35" FontSize="14">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="1.5*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Annulla" Click="BtnAnnulla_Click" Width="100" Height="35" Margin="0,0,10,0"
                    Background="White" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1"/>
            <Button Content="Conferma" Click="BtnConferma_Click" Width="120" Height="35"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
