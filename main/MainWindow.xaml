<Window x:Class="PersonalAutomationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personal Automation Tool" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="White">
    
    <Window.Resources>
        <!-- Stile unificato per i bottoni di navigazione -->
        <Style TargetType="Button" x:Key="NavButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAF2F8"/>
                                <Setter Property="Foreground" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D6EAF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Navbar Estetica senza il "gripper" e la freccia di defult della classica ToolBar WPF -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="5" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button x:Name="BtnHome" Content="HOME" Style="{StaticResource NavButtonStyle}" Click="Nav_Home" />
                <Button x:Name="BtnCartelle" Content="CARTELLE" Style="{StaticResource NavButtonStyle}" Click="Nav_Cartelle" />
                <Button x:Name="BtnPdf" Content="PDF" Style="{StaticResource NavButtonStyle}" Click="Nav_Pdf" />
                <Button x:Name="BtnEmail" Content="EMAIL" Style="{StaticResource NavButtonStyle}" Click="Nav_Email" />
                <Button x:Name="BtnExcel" Content="EXCEL" Style="{StaticResource NavButtonStyle}" Click="Nav_Excel" />
                
                <Rectangle Width="2" Fill="#E2E8F0" Margin="15,10,15,10" RadiusX="1" RadiusY="1"/>
                
                <Button x:Name="BtnDatabase" Content="DATABASE" Style="{StaticResource NavButtonStyle}" Click="Nav_Database" />
            </StackPanel>
        </Border>
        
        <Grid>
            <!-- Area principale dove vengono caricati i moduli -->
            <ContentControl x:Name="MainContentControl" x:FieldModifier="public" />
        </Grid>
    </DockPanel>
</Window>
